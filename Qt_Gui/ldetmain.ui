     <property name="styleSheet">
      <string notr="true">/* Flat design: minimal borders, clean fills, no heavy shadows */
QPushButton {
    min-width: 42px;
    max-width: 42px;
    min-height: 42px;
    max-height: 42px;
    border-radius: 10px;
    background-color: transparent;
    color: #000000;
    font-size: 24px;
    text-align: center;
    border: none;
    padding: 0;
    outline: none;
}

/* Flat hover: subtle background fill instead of heavy outline */
QPushButton:hover {
    background-color: rgba(102, 204, 255, 0.12);
}

/* Flat pressed: stronger flat fill, no border emphasis */
QPushButton:pressed {
    background-color: rgba(51, 153, 221, 0.18);
    padding-left: 2px;
    padding-top: 2px;
}

/* Flat disabled: simple muted tone */
QPushButton:disabled {
    background-color: rgba(0, 0, 0, 0.06);
    color: #b0b0b0;
    border: none;
}</string>
